# Copiá este archivo a .env y completalo. NUNCA subas .env a git.

# Token del bot (lo da @BotFather en Telegram)
TELEGRAM_TOKEN=123456789:AAAA...

# API key de Groq (gratis en https://console.groq.com/keys)
GROQ_API_KEY=gsk_...

# Tu chat ID de Telegram (mandale /start a @userinfobot para conocerlo)
ALLOWED_CHAT_ID=123456789

# Zona horaria para interpretar "mañana a las 10"
TZ=America/Argentina/Buenos_Aires

# --- Opcionales (defaults razonables) ---
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_WHISPER_MODEL=whisper-large-v3-turbo
# GCAL_CALENDAR_ID=primary
